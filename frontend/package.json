{
  "name": "syhionce-frontend",
  "version": "1.0.0",
  "description": "Frontend service for user interest customization application.",
  "main": "src/index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-scripts": "5.0.1",
    "axios": "^0.24.0",
    "react-router-dom": "^6.0.2",
    "redux": "^4.1.2",
    "react-redux": "^7.2.6",
    "redux-thunk": "^2.4.1",
    "prop-types": "^15.8.1",
    "styled-components": "^5.3.3"
  },
  "devDependencies": {
    "eslint": "^8.3.0",
    "eslint-plugin-react": "^7.27.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "prettier": "^2.4.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react/jsx-indent": ["error", 2],
      "react/prop-types": "off"
    }
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.14.0"
  }
}